# ====== SoloMoney Avito OS — пример переменных окружения ======
# Скопируй этот файл в .env и заполни значения. .env в репозиторий не попадает.

# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
# Твой личный Telegram user id (узнать у @userinfobot). Бот работает только для тебя.
OWNER_TELEGRAM_ID=000000000

# --- Gemini ---
# Ключ из Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Модель (по умолчанию быстрая и дешёвая)
GEMINI_MODEL=gemini-2.0-flash

# --- Web / Mini App ---
# Хост и порт локального сервера
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Публичный HTTPS-URL Mini App (для Telegram). Локально можно оставить пустым —
# дашборд тогда открывается в браузере по http://localhost:8000
WEBAPP_URL=

# --- Watcher (мониторинг Avito) ---
# Включить авто-мониторинг при старте (1/0)
WATCHER_ENABLED=1
# Интервал между проходами одного поиска, секунды (минимум/максимум — берётся случайно между ними)
WATCH_INTERVAL_MIN=180
WATCH_INTERVAL_MAX=300
# Сколько новых объявлений за проход догружать ради полного описания
WATCH_MAX_DETAIL_PER_RUN=4
# Headless-режим браузера (1 — без окна; на ПК можно 0, чтобы видеть и решать капчу)
WATCH_HEADLESS=1

# --- Экономика сделок (пороги отсева) ---
# Минимальная абсолютная ЧИСТАЯ прибыль (после расходов), ₽
MIN_PROFIT_RUB=3000
# Минимальная маржа, %
MIN_MARGIN_PCT=12
# Базовые расходы на сделку (дорога, комиссия, мелкий ремонт), вычитаются из прибыли
DEFAULT_COST_RUB=700
# Как часто проверять напоминания по сделкам, минуты
REMINDER_SCAN_MIN=60
# Типичная скидка «выгодного» объявления от рынка (для подбора по бюджету), %
OPPORTUNITY_DISCOUNT_PCT=22
